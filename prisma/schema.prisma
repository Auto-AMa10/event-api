generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int            @id @default(autoincrement())
  email                  String         @unique
  password               String
  name                   String
  role                   Role           @default(CUSTOMER)
  avatarUrl              String?
  pointsBalance          Int            @default(0)
  referralCode           String         @unique
  referredById           Int?
  appLockPin             String?
  twoFactorEnabled       Boolean        @default(false)
  twoFactorCode          String?
  twoFactorCodeExpiresAt DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  provider               Provider       @default(CREDENTIALS)
  bookings               Booking[]
  events                 Event[]
  pointsHistory          PointHistory[]
  refreshToken           RefreshToken?
  reviews                Review[]
  transactions           Transaction[]
  referredBy             User?          @relation("Referral", fields: [referredById], references: [id])
  referrals              User[]         @relation("Referral")

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int      @unique
  expiredAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model PointHistory {
  id        Int       @id @default(autoincrement())
  userId    Int
  amount    Int
  type      String
  expiredAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@map("point_history")
}

model Event {
  id             Int           @id @default(autoincrement())
  organizerId    Int
  title          String        @unique
  description    String
  price          Int
  startDate      DateTime
  endDate        DateTime
  location       String
  availableSeats Int
  totalSeats     Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  categoryId     Int
  slug           String        @unique
  thumbnail      String?
  bookings       Booking[]
  category       Category      @relation(fields: [categoryId], references: [id])
  organizer      User          @relation(fields: [organizerId], references: [id])
  reviews        Review[]
  transactions   Transaction[]
  vouchers       Voucher[]

  @@map("events")
}

model Category {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  slug   String  @unique
  events Event[]

  @@map("categories")
}

model Booking {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventId   Int
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, eventId])
  @@map("bookings")
}

model Transaction {
  id              Int               @id @default(autoincrement())
  userId          Int
  eventId         Int
  status          TransactionStatus @default(WAITING_PAYMENT)
  qty             Int
  totalPrice      Int
  discountApplied Int               @default(0)
  pointsUsed      Int               @default(0)
  paymentProof    String?
  expiresAt       DateTime
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  event           Event             @relation(fields: [eventId], references: [id])
  user            User              @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model Coupon {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  discountPercent Int
  maxDiscount     Int?
  expiresAt       DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("coupons")
}

model Voucher {
  id             Int      @id @default(autoincrement())
  eventId        Int
  code           String   @unique
  discountAmount Int
  expiresAt      DateTime
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  event          Event    @relation(fields: [eventId], references: [id])

  @@map("vouchers")
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventId   Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, eventId])
  @@map("reviews")
}

enum Role {
  CUSTOMER
  ORGANIZER
}

enum Provider {
  CREDENTIALS
  GOOGLE
}

enum TransactionStatus {
  WAITING_PAYMENT
  WAITING_ADMIN
  DONE
  REJECTED
  EXPIRED
  CANCELED
}
